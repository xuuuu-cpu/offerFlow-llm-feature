generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  jobs     Job[]
  resumes  Resume[]
  tasks    Task[]
  reviews  Review[]

  @@map("users")
}

model Job {
  id             String   @id @default(cuid())
  userId         String
  companyName    String
  jobTitle       String
  status         String
  city           String?
  salaryRange    String?
  workMode       String?
  channel        String?
  priority       String?
  appliedDate    String?
  jobLink        String?
  jdText         String?
  resumeId       String?
  contactName    String?
  contactInfo    String?
  nextAction     String?
  notes          String?
  endReason      String?
  interviewRounds Json?
  timeline        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  resume Resume? @relation(fields: [resumeId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
  tasks  Task[]
  reviews Review[]
}

model Resume {
  id         String   @id @default(cuid())
  userId     String
  name       String
  version    String?
  updatedAt  String?
  target     String?
  language   String?
  format     String?
  fileSize   String?
  tags       Json?
  versionNote String?
  fileUrl    String?
  isDefault  Boolean  @default(false)
  fileName   String?
  mimeType   String?
  hasFile    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
  jobs Job[]
}

model Task {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String
  date      String?
  startTime String?
  endTime   String?
  priority  String?
  done      Boolean  @default(false)
  jobId     String?
  notes     String?

  user User @relation(fields: [userId], references: [id])
  job  Job?  @relation(fields: [jobId], references: [id])
}

model Review {
  id              String   @id @default(cuid())
  userId          String
  companyName     String
  jobTitle        String
  jobId           String?
  round           String?
  interviewType   String?
  interviewDate   String?
  duration        String?
  interviewerInfo String?
  result          String?
  rating          Int?
  note            String?
  strengths       String?
  weaknesses      String?
  scores          Json?
  questions       Json?
  tags            Json?
  improvements    Json?
  attachments     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  job  Job?  @relation(fields: [jobId], references: [id])
}
